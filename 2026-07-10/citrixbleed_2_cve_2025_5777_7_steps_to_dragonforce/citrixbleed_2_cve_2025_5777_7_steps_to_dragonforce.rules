# Salamander CTI detection ruleset  //  https://salacti.com
# CitrixBleed 2 (CVE-2025-5777) 7 Steps to Dragonforce Ransomware  (defensive signatures; not endorsements)

alert dns any any -> any any (msg:"[Salamander CTI] DragonForce infrastructure domain"; dns.query; content:"doauthentication.do"; nocase; classtype:trojan-activity; reference:url,https://salacti.com; sid:6100001; rev:1;)
alert dns any any -> any any (msg:"[Salamander CTI] DragonForce infrastructure domain"; dns.query; content:"vpts.us"; nocase; classtype:trojan-activity; reference:url,https://salacti.com; sid:6100002; rev:1;)
alert dns any any -> any any (msg:"[Salamander CTI] DragonForce infrastructure domain"; dns.query; content:"opa.tlsd.shop"; nocase; classtype:trojan-activity; reference:url,https://salacti.com; sid:6100003; rev:1;)
alert dns any any -> any any (msg:"[Salamander CTI] DragonForce infrastructure domain"; dns.query; content:"relay.dltsolutions.top"; nocase; classtype:trojan-activity; reference:url,https://salacti.com; sid:6100004; rev:1;)
alert dns any any -> any any (msg:"[Salamander CTI] DragonForce infrastructure domain"; dns.query; content:"relay.eurofin.digital"; nocase; classtype:trojan-activity; reference:url,https://salacti.com; sid:6100005; rev:1;)
