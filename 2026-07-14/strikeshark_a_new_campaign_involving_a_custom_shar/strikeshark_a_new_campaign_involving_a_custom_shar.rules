# Salamander CTI detection ruleset  //  https://salacti.com
# StrikeShark: a new campaign involving a custom SharkLoader and Cobalt Strike Beacon  (defensive signatures; not endorsements)

alert dns any any -> any any (msg:"[Salamander CTI] Data Insufficient infrastructure domain"; dns.query; content:"connect-microsoft.com"; nocase; classtype:trojan-activity; reference:url,https://salacti.com; sid:6100001; rev:1;)
alert dns any any -> any any (msg:"[Salamander CTI] Data Insufficient infrastructure domain"; dns.query; content:"ms-record.com"; nocase; classtype:trojan-activity; reference:url,https://salacti.com; sid:6100002; rev:1;)
alert dns any any -> any any (msg:"[Salamander CTI] Data Insufficient infrastructure domain"; dns.query; content:"ms-record.top"; nocase; classtype:trojan-activity; reference:url,https://salacti.com; sid:6100003; rev:1;)
alert dns any any -> any any (msg:"[Salamander CTI] Data Insufficient infrastructure domain"; dns.query; content:"ms-tray.top"; nocase; classtype:trojan-activity; reference:url,https://salacti.com; sid:6100004; rev:1;)
